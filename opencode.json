{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    },
    "sqlite": {
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "/tmp",
        "run",
        "mcp-server-sqlite",
        "--db-path",
        "/Users/herbie/dev/tessera/api/data/sqlite.db"
      ],
      "enabled": true
    }
  }
}
